# Flask 配置
# 必须设置！使用以下命令生成：python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secret-key-here

# 登录密码（默认：admin123，首次启动后会自动哈希存储）
# 生产环境建议在部署前直接设置为强密码（至少 8 位）
LOGIN_PASSWORD=admin123

# 是否允许在“系统设置”页面修改登录密码（演示站点建议设为 false）
ALLOW_LOGIN_PASSWORD_CHANGE=true

# 应用配置
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production

# 是否自动启动后台调度器（定时刷新/心跳）。生产建议 true。
SCHEDULER_AUTOSTART=true

# 数据库路径
DATABASE_PATH=data/outlook_accounts.db

# GPTMail 临时邮箱配置
GPTMAIL_BASE_URL=https://mail.chatgpt.org.uk
GPTMAIL_API_KEY=gpt-test

# OAuth2 配置（可选，不填使用默认值）
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_REDIRECT_URI=http://localhost:8080

# 自动更新配置（配合 docker-compose.yml 中的 Watchtower 使用）
# Watchtower HTTP API 地址（默认：http://watchtower:8080）
# WATCHTOWER_API_URL=http://watchtower:8080
# Watchtower HTTP API Token（需与 docker-compose.yml 中的 WATCHTOWER_HTTP_API_TOKEN 一致）
# 使用 python -c "import secrets; print(secrets.token_hex(32))" 生成
WATCHTOWER_HTTP_API_TOKEN=your-watchtower-api-token-here
